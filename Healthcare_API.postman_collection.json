{
  "info": {
    "name": "Healthcare Backend API",
    "description": "Complete API collection for Healthcare Backend - Django REST Framework",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"SecurePass123\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/auth/register/", "host": ["{{base_url}}"], "path": ["api", "auth", "register", ""]}
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.tokens && response.tokens.access) {",
                  "    pm.collectionVariables.set('access_token', response.tokens.access);",
                  "    console.log('Access token saved!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"SecurePass123\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api", "auth", "login", ""]}
          }
        }
      ]
    },
    {
      "name": "Patients",
      "item": [
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Alice Smith\",\n    \"age\": 30,\n    \"gender\": \"Female\",\n    \"address\": \"123 Main St, Mumbai\",\n    \"phone\": \"9876543210\",\n    \"medical_history\": \"Type 2 Diabetes, Hypertension\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/patients/", "host": ["{{base_url}}"], "path": ["api", "patients", ""]}
          }
        },
        {
          "name": "Get All Patients",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/api/patients/", "host": ["{{base_url}}"], "path": ["api", "patients", ""]}
          }
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/api/patients/1/", "host": ["{{base_url}}"], "path": ["api", "patients", "1", ""]}
          }
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"medical_history\": \"Type 2 Diabetes, Hypertension - Under treatment\",\n    \"address\": \"456 New Street, Mumbai\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/patients/1/", "host": ["{{base_url}}"], "path": ["api", "patients", "1", ""]}
          }
        },
        {
          "name": "Delete Patient",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/api/patients/1/", "host": ["{{base_url}}"], "path": ["api", "patients", "1", ""]}
          }
        }
      ]
    },
    {
      "name": "Doctors",
      "item": [
        {
          "name": "Create Doctor",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Dr. Bob Jones\",\n    \"specialization\": \"Endocrinology\",\n    \"phone\": \"9123456789\",\n    \"email\": \"drjones@hospital.com\",\n    \"experience_years\": 10\n}"
            },
            "url": {"raw": "{{base_url}}/api/doctors/", "host": ["{{base_url}}"], "path": ["api", "doctors", ""]}
          }
        },
        {
          "name": "Get All Doctors",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/api/doctors/", "host": ["{{base_url}}"], "path": ["api", "doctors", ""]}
          }
        },
        {
          "name": "Get Doctor by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/api/doctors/1/", "host": ["{{base_url}}"], "path": ["api", "doctors", "1", ""]}
          }
        },
        {
          "name": "Update Doctor",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"experience_years\": 12,\n    \"phone\": \"9999999999\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/doctors/1/", "host": ["{{base_url}}"], "path": ["api", "doctors", "1", ""]}
          }
        },
        {
          "name": "Delete Doctor",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/api/doctors/1/", "host": ["{{base_url}}"], "path": ["api", "doctors", "1", ""]}
          }
        }
      ]
    },
    {
      "name": "Patient-Doctor Mappings",
      "item": [
        {
          "name": "Assign Doctor to Patient",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"patient\": 1,\n    \"doctor\": 1,\n    \"notes\": \"Primary care assignment\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/mappings/", "host": ["{{base_url}}"], "path": ["api", "mappings", ""]}
          }
        },
        {
          "name": "Get All Mappings",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/api/mappings/", "host": ["{{base_url}}"], "path": ["api", "mappings", ""]}
          }
        },
        {
          "name": "Get Doctors for Patient",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/api/mappings/1/", "host": ["{{base_url}}"], "path": ["api", "mappings", "1", ""]}
          }
        },
        {
          "name": "Delete Mapping",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/api/mappings/delete/1/", "host": ["{{base_url}}"], "path": ["api", "mappings", "delete", "1", ""]}
          }
        }
      ]
    }
  ]
}